config BOARD_EKNRF
    select SOC_NRF52840_QIAA if BOARD_EKNRF_NRF52840_ZMK
    select ZMK_BOARD_COMPAT if BOARD_EKNRF_NRF52840_ZMK
    select SOC_NRF52840_QIAA
    imply RETAINED_MEM
    imply RETENTION
    imply RETENTION_BOOT_MODE
